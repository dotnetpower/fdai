# ---------------------------------------------------------------
# Example dev tfvars - copy to `dev.tfvars` (git-ignored) and fill.
# Real values MUST NOT be committed (see generic-scope rules).
# ---------------------------------------------------------------

env          = "dev"
region       = "koreacentral"
region_short = "krc"

# Entra tenant that hosts the executor MI + AAD Postgres auth.
tenant_id = "00000000-0000-0000-0000-000000000000"

# Postgres admin (bootstrap only - production uses AAD auth).
postgres_admin_login    = "fdaiadmin"
postgres_admin_password = "SET-ME-VIA-VAULT"

# Core control-plane image reference (pin by digest for prod).
core_image   = "mcr.microsoft.com/azure-cli:latest"
max_replicas = 3

# Cost-attribution vertical for the fdai:vertical tag (shared |
# resilience | change-safety | cost-governance). Default 'shared'.
# cost_vertical = "shared"

# Fork-supplied tags merged on top of the base FDAI set. Keep the
# `fdai:` namespace; put customer/environment values here, never in
# infra/main.tf base_tags. See deploy-and-onboard.md § Resource Tagging.
additional_tags = {
  "fdai:environment-class" = "dev"
}

# ---------------------------------------------------------------
# Private-networking deploy (policy-locked "private-everything"
# tenants). When true, the deploy MUST run from the bootstrap
# runner inside the ops VNet - the laptop cannot write KV secrets
# to a private-only vault. See infra/bootstrap/README.md.
# ---------------------------------------------------------------
# enable_private_networking = true

# Ops/hub VNet coordinates (from `terraform -chdir=infra/bootstrap output`):
#   ops_vnet_id             -> runner_vnet_id
#   ops_vnet_name           -> runner_vnet_name
#   ops_resource_group_name -> ops_resource_group_name
# runner_vnet_id          = "/subscriptions/.../virtualNetworks/vnet-fdai-ops-krc"
# runner_vnet_name        = "vnet-fdai-ops-krc"
# ops_resource_group_name = "rg-fdai-ops-krc"


# ---------------------------------------------------------------
# Metric analyzer tick (opt-in) - drives the reference threshold
# analyzers so metric-based scenarios (node_cpu_percent,
# http_429_rate, ...) get near-real-time detection. Latency
# envelope: AKS Managed Prometheus ~15-60 s (with Prom wired);
# non-AKS resources ~2-5 min (Azure Monitor Logs ingestion floor).
# Empty cron (default) leaves the job unprovisioned - the demo
# path AKS pod CPU stress etc. is DARK until you fill this in.
# See docs/roadmap/rules-and-detection/observability-and-detection.md.
# ---------------------------------------------------------------
# analyzer_tick_cron_expression = "* * * * *"          # every minute
# analyzer_targets_json = <<-EOT
#   [
#     {"resource_id": "/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.ContainerService/managedClusters/<name>", "kind": "aks_cluster"},
#     {"resource_id": "/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.DBforMySQL/flexibleServers/<name>",       "kind": "mysql_flexible_server"},
#     {"resource_id": "/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<name>",       "kind": "azure_openai"},
#     {"resource_id": "/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.Network/applicationGateways/<name>",      "kind": "application_gateway"},
#     {"resource_id": "/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.ApiManagement/service/<name>",            "kind": "api_management"}
#   ]
# EOT
# analyzer_window_seconds = "300"   # optional; CLI default when unset
# analyzer_budget_seconds = "60"    # optional; CLI default when unset

# Prometheus primary route (recommended for AKS-scoped metrics -
# gives sub-minute detection instead of the AML 2-5 min floor).
# When both prometheus_endpoint and the Log Analytics workspace
# are live, wire_azure_container builds a Prom-first / AML-fallback
# routed metric provider. When only Prom is set it serves what it
# can; other metrics fail-closed.
# prometheus_endpoint = "https://<data-collection-endpoint>.prometheus.monitor.azure.com"
# prometheus_audience = "https://prometheus.monitor.azure.com"

