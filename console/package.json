{
  "name": "fdai-console",
  "version": "0.1.2",
  "type": "module",
  "private": true,
  "description": "FDAI operator console - read-only SPA (KPI dashboard, audit log, HIL queue). See app-shape.instructions.md § Operator console.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && npm run check:entry",
    "check:entry": "node scripts/check-entry-bundle.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude \"tests/e2e/**\"",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@azure/msal-browser": "^3.28.1",
    "@floating-ui/dom": "^1.8.0",
    "hash-wasm": "^4.12.0",
    "highlight.js": "^11.11.1",
    "mermaid": "^11.16.0",
    "preact": "^10.24.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@preact/preset-vite": "^2.10.2",
    "@types/node": "^22.10.0",
    "typescript": "^5.9.0",
    "vite": "^6.3.5",
    "vitest": "^2.1.9"
  }
}
