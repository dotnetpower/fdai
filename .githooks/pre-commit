#!/usr/bin/env bash
# Pre-commit hook - run the repository's staged-file quality gates.
#
# core.hooksPath=.githooks makes this tracked hook authoritative, so it must
# delegate to .pre-commit-config.yaml instead of relying on a generated hook
# under .git/hooks. That catches Ruff lint/format failures before the commit
# reaches pre-push and also runs the framework-surface re-sign hook declared
# in the shared configuration.
#
# Install: make hooks-install (the VS Code folderOpen task does this too)
# Bypass:  git commit --no-verify
set -uo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$repo_root" || exit 1

if ! command -v uv >/dev/null 2>&1; then
  echo "pre-commit: BLOCKED - uv is required. Install uv, then run: uv sync --extra dev" >&2
  exit 1
fi

exec uv run pre-commit run --hook-stage pre-commit
