#!/usr/bin/env -S LC_ALL=C LANG=C bash
# Pre-push hook - lightweight gate for trunk-based (no-branch) collaboration.
#
# Purpose: several people push straight to `main`, so this hook keeps that
# safe by (1) refusing to push when the local branch is behind the remote
# (pull --rebase first, so conflicts surface locally instead of as a
# rejected non-fast-forward push), (2) blocking leftover merge-conflict
# markers, and (3) running a fast ruff lint on only the changed Python
# files. It is intentionally light - no full test suite, no mypy, no build.
#
# Install:  git config core.hooksPath .githooks   (or: make hooks-install)
# Bypass:   git push --no-verify        (git-native, one-off)
#           FDAI_SKIP_PUSH_CHECKS=1 git push
set -uo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$repo_root" || exit 1

if [ "${FDAI_SKIP_PUSH_CHECKS:-0}" = "1" ]; then
  echo "pre-push: skipped (FDAI_SKIP_PUSH_CHECKS=1)"
  exit 0
fi

remote_name="${1:-origin}"
branch="$(git symbolic-ref --short HEAD 2>/dev/null || echo "")"

echo "pre-push: lightweight checks (branch: ${branch:-detached})..."

# ---------------------------------------------------------------------------
# 1. Sync guard - block the push when local is behind the remote branch.
# ---------------------------------------------------------------------------
range=""
if [ -n "$branch" ]; then
  if git fetch --quiet "$remote_name" "$branch" 2>/dev/null; then
    behind="$(git rev-list --count HEAD..FETCH_HEAD 2>/dev/null || echo 0)"
    if [ "$behind" -gt 0 ]; then
      echo "pre-push: BLOCKED - local '$branch' is $behind commit(s) behind $remote_name/$branch."
      echo "  Run:  git pull --rebase        (then push again)"
      echo "  Skip: FDAI_SKIP_PUSH_CHECKS=1 git push   (or: git push --no-verify)"
      exit 1
    fi
    remote_head="$(git rev-parse FETCH_HEAD)"
    local_head="$(git rev-parse HEAD)"
    range="$remote_head..$local_head"
  else
    echo "pre-push: note - '$branch' not on $remote_name yet (new branch); skipping sync + diff checks."
  fi
fi

# Nothing more to check for a brand-new branch with no remote counterpart.
if [ -z "$range" ]; then
  echo "pre-push: OK"
  exit 0
fi

# Files changed in the commits being pushed (skip deletions).
mapfile -t changed < <(git diff --name-only --diff-filter=d "$range" 2>/dev/null || true)
if [ "${#changed[@]}" -eq 0 ]; then
  echo "pre-push: OK (no file changes to lint)"
  exit 0
fi

# Validate the committed snapshot, not the maintainer's working tree. A dirty
# worktree may contain unrelated in-progress files that are absent from the
# push; scanning those files can either block a valid push or validate content
# that the remote will never receive.
validation_parent="$(mktemp -d "${TMPDIR:-/tmp}/fdai-pre-push.XXXXXX")"
validation_root="$validation_parent/worktree"
cleanup_validation_worktree() {
  cd "$repo_root" >/dev/null 2>&1 || true
  git worktree remove --force "$validation_root" >/dev/null 2>&1 || true
  rmdir "$validation_parent" >/dev/null 2>&1 || true
}
trap cleanup_validation_worktree EXIT
if ! git worktree add --quiet --detach "$validation_root" HEAD; then
  echo "pre-push: BLOCKED - failed to create isolated validation worktree."
  exit 1
fi
cd "$validation_root" || exit 1
echo "pre-push: validating committed HEAD in an isolated worktree..."

# ---------------------------------------------------------------------------
# 2. Merge-conflict marker guard.
# Only the two brace-marker forms are unambiguous - the middle '=======' also
# matches RST/Markdown header underlines (e.g. 'Purpose\n=======\n') and
# would cause a false positive on any doc using that style.
# ---------------------------------------------------------------------------
markers=""
for f in "${changed[@]}"; do
  [ -f "$f" ] || continue
  hit="$(grep -HnE '^(<<<<<<< |>>>>>>> )' "$f" 2>/dev/null || true)"
  [ -n "$hit" ] && markers="${markers}${hit}"$'\n'
done
if [ -n "$markers" ]; then
  echo "pre-push: BLOCKED - merge-conflict markers found:"
  printf '%s' "$markers"
  exit 1
fi

# ---------------------------------------------------------------------------
# 3. Fast ruff lint on changed Python files under src/ and tests/.
# ---------------------------------------------------------------------------
py=()
for f in "${changed[@]}"; do
  case "$f" in
    src/*.py | tests/*.py) [ -f "$f" ] && py+=("$f") ;;
  esac
done
if [ "${#py[@]}" -gt 0 ]; then
  echo "pre-push: ruff check on ${#py[@]} changed Python file(s)..."
  if command -v uv >/dev/null 2>&1; then
    if ! uv run ruff check "${py[@]}"; then
      echo "pre-push: BLOCKED - ruff check failed. Fix, or run: uv run ruff check --fix ${py[*]}"
      exit 1
    fi
    # Format gate: CI runs `ruff format --check src tests` and a single
    # unformatted file fails the whole lint/mypy/pytest job before it even
    # starts. Catch it here so an unformatted file never reaches CI.
    if ! uv run ruff format --check "${py[@]}"; then
      echo "pre-push: BLOCKED - ruff format check failed. Run: uv run ruff format ${py[*]}"
      exit 1
    fi
  else
    echo "pre-push: note - uv not found; skipping ruff lint."
  fi
fi

# ---------------------------------------------------------------------------
# 4. Framework-surface guard. Upstream: advisory warning (exit 0, never
#    blocks a push). Fork (FDAI_FORK=1 / .fdai-fork / git config fdai.fork):
#    hard block on any edit under src/fdai/core, composition.py, the provider
#    Protocols, contracts, agents, rule-catalog/schema, or .github/instructions.
# ---------------------------------------------------------------------------
if [ -x scripts/integrity/check-protected-paths.sh ] || [ -f scripts/integrity/check-protected-paths.sh ]; then
  if ! bash scripts/integrity/check-protected-paths.sh "$range"; then
    echo "pre-push: BLOCKED - framework-surface guard (fork mode)."
    exit 1
  fi
fi

# ---------------------------------------------------------------------------
# 4b. Framework-surface integrity (offline signed manifest). Verifies the
#     signature + content of every framework-surface file against the
#     upstream-signed security/integrity/manifest.json. Fork: a content
#     mismatch (edited/added/deleted surface file) is a HARD BLOCK. Upstream:
#     advisory (rc 0) - re-sign before release. Skipped until the signed
#     manifest exists so a fresh checkout never fails on a missing artifact.
# ---------------------------------------------------------------------------
if [ -f scripts/integrity/check-integrity.sh ] && [ -f security/integrity/manifest.json.sig ]; then
  if ! bash scripts/integrity/check-integrity.sh; then
    echo "pre-push: BLOCKED - framework-surface integrity (fork mode)."
    exit 1
  fi
fi

# ---------------------------------------------------------------------------
# 4c. Design-document impact. Routes behavior-bearing paths through the
#     machine-readable design registry and requires an owning design doc in
#     the same pushed range.
# ---------------------------------------------------------------------------
if [ -f scripts/quality/architecture/check-design-doc-impact.py ]; then
  if ! python3 scripts/quality/architecture/check-design-doc-impact.py "$range"; then
    echo "pre-push: BLOCKED - owning design documentation was not updated."
    exit 1
  fi
fi
if [ -f scripts/quality/architecture/check-document-size.py ]; then
  if ! python3 scripts/quality/architecture/check-document-size.py "$range"; then
    echo "pre-push: BLOCKED - oversized roadmap document grew instead of being split."
    exit 1
  fi
fi

# ---------------------------------------------------------------------------
# 5. Structural gates (warn-only in the hook - CI is the authoritative
#    fail surface). Kept lightweight so pushes stay fast. Tracker #14,
#    issue #22.
# ---------------------------------------------------------------------------
for gate_path in \
  scripts/quality/architecture/check-agents-imports.sh \
  scripts/quality/architecture/check-design-routes.py \
  scripts/quality/architecture/check-fork-runtime-independence.py \
  scripts/quality/architecture/check-file-loc.sh \
  scripts/quality/architecture/check-subsystem-fanout.sh \
  scripts/quality/repository/check-doc-links.sh
do
  gate="${gate_path##*/}"
  gate="${gate%.sh}"
  if [ ! -f "$gate_path" ]; then
    echo "pre-push: BLOCKED - required structural gate is missing: $gate_path"
    exit 1
  fi
  # Pre-push runs in warn-only mode for the two threshold gates (H2/H5
  # give them their loud voices in CI); suppress per-file lines with
  # CHECK_QUIET so a routine push does not flood the terminal.
  if [[ "$gate_path" == *.py ]]; then
    gate_command=(python3 "$gate_path")
  else
    gate_command=(bash "$gate_path")
  fi
  if ! CHECK_QUIET=1 "${gate_command[@]}" > /tmp/pre-push-${gate}.out 2>&1; then
    echo "pre-push: BLOCKED - ${gate} failed:"
    sed 's/^/  /' /tmp/pre-push-${gate}.out
    exit 1
  fi
done

echo "pre-push: OK"
exit 0
