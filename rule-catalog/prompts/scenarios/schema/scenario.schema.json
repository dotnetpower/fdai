{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aiopspilot.dev/schemas/rule-catalog/scenario/1.0.0",
  "title": "Recognition Scenario",
  "description": "One authored scenario the recognition-probe runner (Wave 3 step D-2b-ii) executes. Each scenario names a capability, an optional scope, and the ground-truth contract the model response is scored against.",
  "type": "object",
  "required": ["id", "version", "capability_id", "expected"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9.\\-]*$",
      "description": "Stable identifier. Version is a separate field so id stays stable across versions."
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "capability_id": {
      "type": "string",
      "minLength": 1,
      "description": "The composer capability to invoke (e.g. 't2.reasoner.primary')."
    },
    "scope": {
      "type": "object",
      "description": "Operator-memory scope threaded to the composer. Omit for scenarios that do not exercise operator memory.",
      "additionalProperties": false,
      "required": ["resource_group_ref"],
      "properties": {
        "resource_group_ref": {"type": "string", "minLength": 1},
        "resource_ref": {"type": "string", "minLength": 1}
      }
    },
    "expected": {
      "type": "object",
      "description": "Ground-truth contract the recognition probe scores against.",
      "required": ["required_fields"],
      "additionalProperties": false,
      "properties": {
        "required_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "expected_type"],
            "additionalProperties": false,
            "properties": {
              "name": {"type": "string", "minLength": 1},
              "expected_type": {"enum": ["string", "object", "array"]},
              "non_empty": {"type": "boolean"}
            }
          }
        },
        "expected_cited_rule_ids": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "description": "Ground-truth rule ids the model's cited_rule_ids field SHOULD carry. Empty = skip citation scoring."
        },
        "canary_tokens": {
          "type": "object",
          "additionalProperties": {"type": "string", "minLength": 1},
          "description": "Explicit canary tokens to score against. Omit to auto-promote the composer's tokens."
        }
      }
    },
    "provenance": {
      "type": "object",
      "required": ["source"],
      "additionalProperties": false,
      "properties": {
        "source": {"type": "string", "minLength": 1},
        "notes": {"type": "string"}
      }
    }
  }
}
