{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fdai.dev/schemas/view/1.0.0",
  "title": "Process ViewSpec",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "name", "route", "applies_to", "regions"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]{1,63}$"},
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "name": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "route": {"type": "string", "pattern": "^/processes/\\{process_id\\}$"},
    "applies_to": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workflow_ref"],
      "properties": {
        "workflow_ref": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]{0,79}$"}
      }
    },
    "regions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "report_ref"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9_-]{0,63}$"},
          "report_ref": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,63}$"},
          "column_span": {"type": "integer", "minimum": 1, "maximum": 12, "default": 12}
        }
      }
    }
  }
}
