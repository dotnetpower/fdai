{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aiopspilot.dev/schemas/action/1.0.0",
  "title": "Action",
  "description": "An autonomous action proposed by a tier and gated by risk. Every field required by the four safety invariants (stop-condition, rollback path, blast radius, audit entry) is mandatory.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "action_id",
    "idempotency_key",
    "event_id",
    "action_type",
    "target_resource_ref",
    "operation",
    "stop_condition",
    "rollback_ref",
    "blast_radius",
    "mode",
    "citing_rules",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "action_id": {
      "type": "string",
      "format": "uuid"
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "description": "Derived from the triggering event so retries are no-ops."
    },
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "Event that triggered this action."
    },
    "action_type": {
      "type": "string",
      "description": "Refers to an ontology ActionType.name."
    },
    "target_resource_ref": {
      "type": "string",
      "description": "Ontology Resource id the action targets."
    },
    "operation": {
      "type": "string",
      "enum": [
        "create",
        "update",
        "delete",
        "disable",
        "enable",
        "tag",
        "drop",
        "purge"
      ]
    },
    "params": {
      "type": "object",
      "additionalProperties": true,
      "description": "Operation parameters (already verifier-checked; no untrusted text past this point)."
    },
    "stop_condition": {
      "type": "string",
      "minLength": 1,
      "description": "Named halt state that aborts the action. Safety invariant #1."
    },
    "rollback_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "pr_revert",
            "scripted",
            "none"
          ]
        },
        "reference": {
          "type": [
            "string",
            "null"
          ],
          "description": "PR id, script path, or null."
        }
      },
      "description": "How to revert. kind=none is only legal on inherently non-mutating actions and MUST be justified."
    },
    "blast_radius": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope"
      ],
      "properties": {
        "scope": {
          "type": "string",
          "enum": [
            "resource",
            "resource_group",
            "subscription"
          ]
        },
        "count": {
          "type": "integer",
          "minimum": 1
        },
        "rate_per_minute": {
          "type": "integer",
          "minimum": 1
        }
      },
      "description": "Blast-radius limit. scope=subscription is denied by the default risk table."
    },
    "mode": {
      "type": "string",
      "enum": [
        "shadow",
        "enforce"
      ]
    },
    "citing_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "description": "Rule ids that justify this action. Empty list = ungrounded and MUST NOT execute."
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
