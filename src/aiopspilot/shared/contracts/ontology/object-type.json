{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aiopspilot.dev/schemas/ontology/object-type/1.0.0",
  "title": "OntologyObjectType",
  "description": "Declares one entity type in the ontology (e.g. Resource, Rule, Signal, Finding).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "name",
    "version",
    "key",
    "properties"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "name": {
      "type": "string",
      "pattern": "^[A-Z][A-Za-z0-9]{0,63}$",
      "description": "PascalCase entity name."
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "key": {
      "type": "string",
      "description": "Property name that uniquely identifies an instance."
    },
    "properties": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "string",
              "integer",
              "number",
              "boolean",
              "object",
              "array",
              "datetime"
            ]
          },
          "required": {
            "type": "boolean",
            "default": false
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "description": {
      "type": "string"
    }
  }
}
