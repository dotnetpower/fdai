{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fdai.dev/schemas/workflow/1.0.0",
  "title": "Workflow",
  "description": "Declarative business process: an ordered list of steps, each referencing one ontology ActionType, plus a trigger, a promotion gate, and a default mode. Catalog-as-code under rule-catalog/workflows/. Design contract: docs/roadmap/decisioning/process-automation.md.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "name",
    "version",
    "trigger",
    "promotion_gate",
    "steps"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_.-]{0,79}$",
      "description": "Stable dotted id, e.g. `cost-aware-remediation`. The audit key; the loader dedupes on it."
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": {
      "type": ["string", "null"],
      "maxLength": 200,
      "description": "<= 200 chars, English, no marketing."
    },
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["signal", "schedule"]
        },
        "signal_type": {
          "type": ["string", "null"],
          "description": "Signal type that starts the flow. Required when kind == signal."
        },
        "schedule": {
          "type": ["string", "null"],
          "description": "Cron / RFC-5545-style schedule. Required when kind == schedule."
        }
      }
    },
    "default_mode": {
      "type": "string",
      "enum": ["shadow", "enforce"],
      "default": "shadow",
      "description": "Upstream workflows MUST default to shadow; promotion to enforce is a separate gated governance PR."
    },
    "promotion_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min_shadow_days",
        "min_samples",
        "min_accuracy",
        "max_policy_escapes"
      ],
      "properties": {
        "min_shadow_days": {
          "type": "integer",
          "minimum": 1
        },
        "min_samples": {
          "type": "integer",
          "minimum": 1
        },
        "min_accuracy": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "max_policy_escapes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "description": "Step id unique within the workflow. Referenced by `on_failure` on another step."
          },
          "kind": {
            "type": "string",
            "enum": ["action", "wait", "approval", "decision", "parallel", "gate"],
            "default": "action"
          },
          "action_type_ref": {
            "type": ["string", "null"],
            "minLength": 1,
            "description": "ActionType name this step invokes (e.g. `remediate.right-size`). MUST resolve against the ActionType catalog at load."
          },
          "guard_rule_ref": {
            "type": ["string", "null"],
            "description": "Optional Rule id that gates the step. The deterministic `when` for the step; MUST resolve against the rule catalog when set."
          },
          "gate_ref": {
            "type": ["string", "null"],
            "minLength": 1,
            "description": "Deterministic non-resource gate reference used by a gate step."
          },
          "compensated_by": {
            "type": ["string", "null"],
            "description": "Optional ActionType name that reverses this step (saga rollback). MUST resolve against the ActionType catalog when set."
          },
          "on_failure": {
            "type": ["string", "null"],
            "description": "Step id to run when this step fails. MUST reference an existing step id in the same workflow when set."
          },
          "params": {
            "type": "object",
            "additionalProperties": {
              "type": ["string", "number", "integer", "boolean"]
            },
            "description": "Optional scalar arguments for the step. String values MAY carry ${event.resource_ref} / ${event.trigger_ts} / ${event.event_type} tokens the orchestrator substitutes from the triggering event at run time."
          },
          "wait_for": {
            "type": ["string", "null"],
            "minLength": 1
          },
          "timeout_seconds": {
            "type": ["integer", "null"],
            "minimum": 1
          },
          "approval_role": {
            "type": ["string", "null"],
            "enum": ["reader", "contributor", "approver", "owner", null]
          },
          "quorum": {
            "type": "integer",
            "minimum": 1,
            "default": 1
          },
          "no_self_approval": {
            "type": "boolean",
            "default": true
          },
          "outcomes": {
            "type": "array",
            "items": {"type": "string", "pattern": "^[a-z][a-z0-9_-]{0,63}$"},
            "uniqueItems": true,
            "default": []
          },
          "branches": {
            "type": "array",
            "items": {"type": "string", "pattern": "^[a-z][a-z0-9_-]{0,63}$"},
            "uniqueItems": true,
            "default": []
          }
        },
        "allOf": [
          {
            "if": {"properties": {"kind": {"const": "action"}}},
            "then": {"required": ["action_type_ref"]}
          },
          {
            "if": {"required": ["kind"], "properties": {"kind": {"const": "wait"}}},
            "then": {"required": ["wait_for", "timeout_seconds"]}
          },
          {
            "if": {"required": ["kind"], "properties": {"kind": {"const": "approval"}}},
            "then": {"required": ["approval_role", "timeout_seconds"]}
          },
          {
            "if": {"required": ["kind"], "properties": {"kind": {"const": "decision"}}},
            "then": {"required": ["outcomes"]}
          },
          {
            "if": {"required": ["kind"], "properties": {"kind": {"const": "parallel"}}},
            "then": {"required": ["branches"]}
          },
          {
            "if": {"required": ["kind"], "properties": {"kind": {"const": "gate"}}},
            "then": {"required": ["gate_ref"]}
          }
        ]
      }
    },
    "anti_scope": {
      "type": ["string", "null"],
      "description": "Optional; what the workflow deliberately does not do."
    }
  }
}
