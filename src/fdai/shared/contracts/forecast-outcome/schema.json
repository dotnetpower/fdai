{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fdai.dev/schemas/forecast-outcome/1.0.0",
  "title": "ForecastOutcome",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "outcome_id", "idempotency_key", "correlation_id",
    "detector_id", "detector_version", "access_scope_digest", "target_digest", "metric",
    "feature_cutoff", "horizon_started_at", "horizon_ended_at", "direction",
    "threshold", "label", "evidence_refs", "telemetry_completeness", "closed_at", "mode"
  ],
  "properties": {
    "schema_version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "outcome_id": {"type": "string", "format": "uuid"},
    "idempotency_key": {"type": "string", "minLength": 1, "maxLength": 512},
    "correlation_id": {"type": "string", "minLength": 1, "maxLength": 512},
    "prediction_id": {"type": ["string", "null"], "format": "uuid"},
    "detector_id": {"type": "string", "minLength": 1, "maxLength": 512},
    "detector_version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "access_scope_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "target_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "metric": {"type": "string", "minLength": 1, "maxLength": 512},
    "feature_cutoff": {"type": "string", "format": "date-time"},
    "horizon_started_at": {"type": "string", "format": "date-time"},
    "horizon_ended_at": {"type": "string", "format": "date-time"},
    "direction": {"type": "string", "enum": ["rising", "falling"]},
    "threshold": {"type": "number"},
    "predicted_value": {"type": ["number", "null"]},
    "interval_lower": {"type": ["number", "null"]},
    "interval_upper": {"type": ["number", "null"]},
    "observed_value": {"type": ["number", "null"]},
    "actual_breach_at": {"type": ["string", "null"], "format": "date-time"},
    "label": {
      "type": "string",
      "enum": [
        "true_positive", "false_positive", "false_negative", "late_breach",
        "magnitude_error", "intervention_censored", "unscorable"
      ]
    },
    "intervention_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1, "maxLength": 512},
      "default": []
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1, "maxLength": 512}
    },
    "telemetry_completeness": {
      "type": "string",
      "enum": ["complete", "partial", "unavailable"]
    },
    "closed_at": {"type": "string", "format": "date-time"},
    "mode": {"type": "string", "enum": ["shadow", "enforce"], "default": "shadow"}
  },
  "allOf": [
    {
      "if": {"properties": {"label": {"const": "false_negative"}}},
      "then": {
        "required": ["actual_breach_at"],
        "properties": {
          "prediction_id": {"type": "null"},
          "predicted_value": {"type": "null"},
          "interval_lower": {"type": "null"},
          "interval_upper": {"type": "null"},
          "actual_breach_at": {"type": "string", "format": "date-time"}
        }
      },
      "else": {
        "required": ["prediction_id"],
        "properties": {"prediction_id": {"type": "string", "format": "uuid"}}
      }
    },
    {
      "if": {
        "properties": {
          "label": {"enum": ["true_positive", "late_breach", "magnitude_error"]}
        }
      },
      "then": {
        "required": ["actual_breach_at"],
        "properties": {"actual_breach_at": {"type": "string", "format": "date-time"}}
      }
    },
    {
      "if": {"properties": {"label": {"enum": ["false_positive", "intervention_censored"]}}},
      "then": {"properties": {"actual_breach_at": {"type": "null"}}}
    },
    {
      "if": {"properties": {"label": {"const": "intervention_censored"}}},
      "then": {
        "required": ["intervention_refs"],
        "properties": {"intervention_refs": {"minItems": 1}}
      }
    },
    {
      "if": {"properties": {"label": {"const": "false_positive"}}},
      "then": {"properties": {"intervention_refs": {"maxItems": 0}}}
    },
    {
      "if": {"properties": {"label": {"const": "unscorable"}}},
      "then": {"properties": {"telemetry_completeness": {"enum": ["partial", "unavailable"]}}}
    },
    {
      "if": {"properties": {"telemetry_completeness": {"enum": ["partial", "unavailable"]}}},
      "then": {"properties": {"label": {"const": "unscorable"}}}
    },
    {
      "if": {"properties": {"label": {"const": "magnitude_error"}}},
      "then": {
        "required": ["observed_value", "interval_lower", "interval_upper"],
        "properties": {
          "observed_value": {"type": "number"},
          "interval_lower": {"type": "number"},
          "interval_upper": {"type": "number"}
        }
      }
    }
  ]
}
