{
  "name": "@fdai/architecture-diagrams",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Compile FDAI architecture diagram specifications into static and interactive documentation assets.",
  "scripts": {
    "test": "node --import tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "validate": "tsx src/cli.ts validate",
