{
  "version": 1,
  "instruction_line_budget": 220,
  "routes": [
    {
      "id": "baseline",
      "paths": ["**"],
      "must_read": [
        ".github/copilot-instructions.md"
      ],
      "validate": ["scripts/verify.sh"]
    },
    {
      "id": "issue-lifecycle",
      "paths": [
        ".github/ISSUE_TEMPLATE/**",
        ".github/workflows/issue-lifecycle.yml",
        "CONTRIBUTING.md",
        "scripts/quality/repository/check-issue-lifecycle.py"
      ],
      "must_read": [
        ".github/copilot-instructions.md",
        "CONTRIBUTING.md"
      ],
      "validate": [
        "python3 scripts/quality/repository/check-issue-lifecycle.py"
      ]
    },
    {
      "id": "python",
      "paths": ["src/**/*.py", "tests/**/*.py"],
      "must_read": [
        ".github/instructions/coding-conventions.instructions.md"
      ],
      "validate": ["uv run ruff check", "uv run mypy"]
    },
    {
      "id": "architecture-core",
      "paths": ["src/fdai/core/**", "src/fdai/shared/**", "src/fdai/composition/**"],
      "must_read": [
        ".github/instructions/architecture.instructions.md",
        "docs/roadmap/architecture/project-structure.md",
        "docs/roadmap/architecture/code-map.md"
      ],
      "docs_update": [
        "docs/roadmap/architecture/project-structure.md",
        "docs/roadmap/architecture/code-map.md",
        "docs/roadmap/architecture/decisions/0002-independent-runtime-axes.md"
      ]
    },
    {
      "id": "mscp-operational-profile",
      "paths": [
        "src/fdai/core/mscp_profile/**",
        "tests/core/mscp_profile/**"
      ],
      "optional_paths": [
        "src/fdai/core/control_loop/_execution.py",
        "src/fdai/core/control_loop/orchestrator.py",
        "src/fdai/composition/_helpers.py",
        "src/fdai/runtime/control_loop.py"
      ],
      "must_read": [
        ".github/instructions/architecture.instructions.md",
        "docs/roadmap/architecture/mscp-operational-profile.md"
      ],
      "docs_update": [
        "docs/roadmap/architecture/mscp-operational-profile.md",
        "docs/roadmap/architecture/code-map.md",
        "docs/roadmap/architecture/project-structure.md"
      ],
      "validate": [
        "uv run pytest -q --no-cov tests/core/mscp_profile",
        "uv run ruff check src/fdai/core/mscp_profile src/fdai/core/control_loop/_execution.py src/fdai/core/control_loop/orchestrator.py src/fdai/composition/_helpers.py src/fdai/runtime/control_loop.py tests/core/mscp_profile",
        "uv run mypy src/fdai/core/mscp_profile src/fdai/core/control_loop/_execution.py src/fdai/core/control_loop/orchestrator.py src/fdai/composition/_helpers.py src/fdai/runtime/control_loop.py tests/core/mscp_profile"
      ]
