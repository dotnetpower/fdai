{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Design Mocks: Static Site",
      "type": "node-terminal",
      "request": "launch",
      "command": "python3 -u -m http.server 5373 --bind 127.0.0.1",
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "Serving HTTP on 127\\.0\\.0\\.1 port 5373",
        "uriFormat": "http://127.0.0.1:5373",
        "action": "debugWithChrome"
      }
    },
    {
      "name": "Console Web: Core Runtime",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "module": "fdai",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "console: prepare full stack",
      "envFile": "${workspaceFolder}/.fdai/local-runtime.env",
      "console": "integratedTerminal",
      "justMyCode": true,
      "subProcess": true
    },
    {
      "name": "Console Web: Read API",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "module": "uvicorn",
      "args": [
        "fdai.delivery.read_api.dev.local:app",
        "--factory",
        "--host",
        "127.0.0.1",
        "--port",
        "8010",
        "--reload"
      ],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "console: prepare full stack",
      "envFile": "${workspaceFolder}/.fdai/local-runtime.env",
      "env": {
        "FDAI_READ_API_LOCAL_ENTRA": "1",
        "FDAI_READ_API_DEV_MODE": "0",
        "FDAI_READ_API_LOCAL_AZURE_CLI": "0",
        "FDAI_READ_API_EMBED_PANTHEON": "0",
        "FDAI_LOCAL_AZURE_DISCOVERY": "1",
        "FDAI_LOCAL_SCENARIO_REPLAY": "0",
        "FDAI_READ_API_CORS_ALLOW_ORIGINS": "http://127.0.0.1:5273,http://localhost:5273"
      },
      "console": "integratedTerminal",
      "justMyCode": true,
      "subProcess": true
    },
    {
      "name": "Console Web: Ingestion Gateway",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "module": "uvicorn",
      "args": [
        "fdai.delivery.ingestion_gateway.dev:app",
        "--factory",
        "--host",
        "127.0.0.1",
        "--port",
        "8011",
        "--reload"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "FDAI_INGESTION_GATEWAY_DEV_MODE": "1",
        "FDAI_INGESTION_GATEWAY_CORS_ALLOW_ORIGINS": "http://127.0.0.1:5273,http://localhost:5273"
      },
      "console": "integratedTerminal",
      "justMyCode": true,
      "subProcess": true
    },
    {
      "name": "Console Web: Frontend",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev -- --port 5273 --strictPort",
      "cwd": "${workspaceFolder}/console",
      "env": {
        "VITE_LOCAL_AZURE_CLI_AUTH": "0",
        "VITE_DEV_MODE": "0",
        "VITE_LOCAL_LOGIN_PROMPT": "0",
        "VITE_READ_API_BASE_URL": "http://127.0.0.1:8010",
        "VITE_INGESTION_API_BASE_URL": "http://127.0.0.1:8011"
      },
      "serverReadyAction": {
        "pattern": "Local:\\s+(https?://\\S+)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      }
    }
  ],
  "compounds": [
    {
      "name": "Console Web: Full Stack",
      "configurations": [
        "Console Web: Core Runtime",
        "Console Web: Read API",
        "Console Web: Frontend"
      ],
      "stopAll": true
    }
  ]
}
