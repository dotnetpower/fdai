---
/*
 * CustomHero.astro - Starlight <Hero> override for the landing page.
 *
 * Adds three visual touches from examples/option-b-tailwind.html that
 * the default Starlight hero lacks:
 *
 *   1. A soft radial-glow backdrop behind the hero, mirroring the
 *      mockup's `.glow` layer (two overlapping radial gradients in
 *      the Azure palette). Rendered as an ::before pseudo-element on
 *      a wrapping <div> so it sits behind the hero content without
 *      touching Starlight's own layout.
 *   2. A gradient sweep on the H1 text (from `--sl-color-text-accent`
 *      to the Azure accent cyan) so the tagline reads as a proper
 *      landing headline instead of a stock docs title.
 *   3. An abstract inline SVG node-and-edge illustration in the
 *      background, evoking the control-loop shape the site describes
 *      (events streaming in on the left, converging through a
 *      triage funnel, fanning out to actions on the right). No
 *      real UI to screenshot yet, so the visual is intentionally
 *      abstract; when a real dashboard exists this SVG is a
 *      one-file swap.
 *
 * The Starlight default Hero is delegated to for everything else
 * (buttons, tagline text, image slot, actions), so this override is
 * additive rather than replacing Starlight's behaviour.
 *
 * One fix-up before delegation: Starlight's Hero renders
 * `hero.actions[].link` verbatim into `<LinkButton href>`, which does
 * NOT prepend Astro's configured `base`. On a GitHub Pages project
 * page (base = "/fdai") that turns a landing CTA authored as
 * `/get-started/` into a link to the user-site root, giving a 404.
 * Rewrite each internal action link through `import.meta.env.BASE_URL`
 * so the base is applied at build time - fork owners that override
 * `BASE_PATH` via env still get the correct prefix without editing
 * `index.mdx`. Absolute URLs and links that already start with the
 * base are left untouched.
 */

import Default from "@astrojs/starlight/components/Hero.astro";
import NebulaBackground from "./NebulaBackground.astro";

const BASE = import.meta.env.BASE_URL; // trailing-slash form, e.g. "/fdai/"

/** @param {string | undefined} link */
function withBase(link) {
  if (!link) return link;
  if (/^(?:[a-z][a-z0-9+.-]*:)?\/\//i.test(link)) return link; // external
  if (link.startsWith("#") || link.startsWith("?")) return link;
  const base = BASE.endsWith("/") ? BASE : BASE + "/";
  if (link.startsWith(base)) return link;
  const normalized = link.startsWith("/") ? link.slice(1) : link;
  return base + normalized;
}

const route = Astro.locals.starlightRoute;
const hero = route?.entry?.data?.hero;
if (hero?.actions?.length) {
  // Shallow-clone so we do not mutate the shared route entry data.
  hero.actions = hero.actions.map((a) => ({ ...a, link: withBase(a.link) }));
}

// The kicker label belongs to the landing hero only. Starlight's generated
// 404 page reuses this Hero override (and carries its own hero data), so gate
// the kicker on the route: hide it on the 404. Detect it by slug/id (works in
// dev, where the not-found renders at the requested path) with a pathname
// fallback (the built 404 emits at /404).
const pathname = Astro.url.pathname.replace(/\/$/, "");
const slug = route?.entry?.slug;
const id = route?.id;
const is404 =
  slug === "404" ||
  id === "404" ||
  id === "404.md" ||
  pathname.endsWith("/404");
---

<NebulaBackground intensity={1.0} speed={1.0} attachToBody />
<div class="landing-hero">
  <svg
    class="landing-hero-art"
    viewBox="0 0 800 400"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <defs>
      <linearGradient id="edge-gradient" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#0078D4" stop-opacity="0.55" />
        <stop offset="100%" stop-color="#50E6FF" stop-opacity="0.35" />
      </linearGradient>
      <radialGradient id="node-glow" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#50E6FF" stop-opacity="0.9" />
        <stop offset="100%" stop-color="#0078D4" stop-opacity="0" />
      </radialGradient>
    </defs>

    <!-- Incoming events (left cluster) -->
    <g class="hero-events">
      <circle cx="60" cy="90" r="4" fill="#0078D4" />
      <circle cx="90" cy="140" r="3" fill="#0078D4" opacity="0.7" />
      <circle cx="55" cy="200" r="5" fill="#0078D4" />
      <circle cx="100" cy="260" r="3" fill="#0078D4" opacity="0.7" />
      <circle cx="70" cy="320" r="4" fill="#0078D4" opacity="0.85" />
      <circle cx="130" cy="90" r="3" fill="#50E6FF" opacity="0.7" />
      <circle cx="140" cy="220" r="4" fill="#50E6FF" opacity="0.6" />
    </g>

    <!-- Trust-router funnel: converging edges into the middle node -->
    <g class="hero-funnel-edges" stroke="url(#edge-gradient)" stroke-width="1.5" fill="none">
      <path d="M60 90 Q220 180 400 200" />
      <path d="M90 140 Q220 170 400 200" />
      <path d="M55 200 L400 200" />
      <path d="M100 260 Q220 230 400 200" />
      <path d="M70 320 Q220 260 400 200" />
      <path d="M130 90 Q260 150 400 200" opacity="0.6" />
      <path d="M140 220 Q260 220 400 200" opacity="0.6" />
    </g>

    <!-- Central router node -->
    <circle cx="400" cy="200" r="60" fill="url(#node-glow)" opacity="0.4" />
    <circle cx="400" cy="200" r="16" fill="#0078D4" />
    <circle class="hero-router-pulse" cx="400" cy="200" r="24" fill="none" stroke="#50E6FF" stroke-width="1.5" opacity="0.6" />
    <circle class="hero-router-pulse ring-2" cx="400" cy="200" r="34" fill="none" stroke="#50E6FF" stroke-width="1" opacity="0.35" />

    <!-- Tier lanes: three horizontal branches to the right -->
    <g class="hero-tier-lanes" stroke="url(#edge-gradient)" stroke-width="1.5" fill="none">
      <path d="M416 200 Q560 130 720 90" />
      <path d="M416 200 L720 200" />
      <path d="M416 200 Q560 270 720 310" />
    </g>

    <!-- Routed event packets travelling the three tier lanes. Decorative;
         disabled under prefers-reduced-motion. Positioned by CSS
         offset-path; a browser without offset-path keeps them hidden. -->
    <g class="hero-packets" aria-hidden="true">
      <circle class="hero-packet hero-packet--t0" r="4" fill="#50E6FF" opacity="0" />
      <circle class="hero-packet hero-packet--t1" r="4" fill="#50E6FF" opacity="0" />
      <circle class="hero-packet hero-packet--t2" r="4" fill="#50E6FF" opacity="0" />
    </g>

    <!-- Output nodes: T0/T1/T2 -> action -->
    <g>
      <circle cx="720" cy="90" r="10" fill="#0078D4" />
      <circle cx="720" cy="200" r="10" fill="#50E6FF" opacity="0.85" />
      <circle cx="720" cy="310" r="10" fill="#0078D4" opacity="0.75" />

      <circle class="hero-out-pulse" cx="720" cy="90" r="18" fill="none" stroke="#0078D4" stroke-width="1" opacity="0.4" />
      <circle class="hero-out-pulse" style="animation-delay: 0.7s" cx="720" cy="200" r="18" fill="none" stroke="#50E6FF" stroke-width="1" opacity="0.4" />
      <circle class="hero-out-pulse" style="animation-delay: 1.3s" cx="720" cy="310" r="18" fill="none" stroke="#0078D4" stroke-width="1" opacity="0.3" />
    </g>

    <!-- Faint horizontal "audit log" band anchoring the composition -->
    <line
      x1="0"
      y1="380"
      x2="800"
      y2="380"
      stroke="#0078D4"
      stroke-opacity="0.15"
      stroke-width="1"
      stroke-dasharray="4 6"
    />
  </svg>
  {!is404 && <p class="hero-kicker">FDAI - Forward Deployed Agents for Cloud Ops</p>}
  <Default {...Astro.props}><slot /></Default>
</div>

<style>
  .landing-hero {
    position: relative;
    isolation: isolate;
    /* Immersive splash: fill the first screen and centre the hero
       content (demo-style) over the nebula for an overwhelming feel. */
    min-height: calc(100vh - 4rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    padding-block: 4rem 3rem;
    padding-inline: 1.5rem;
    margin-block-end: 1rem;
  }
  /* Centre Starlight's hero: override its grid with a centred flex
     column so the title/tagline/actions block sits in the middle of the
     viewport instead of hugging the left grid track. */
  .landing-hero :global(.hero) {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 62rem;
    margin-inline: auto;
    /* Starlight gives .hero a large responsive top padding (~96px) that
       left the kicker floating far above the title. Zero it so the
       kicker sits just above the headline, demo-style. */
    padding-block: 0;
  }
  .landing-hero :global(.hero .stack) {
    align-items: center;
    text-align: center;
  }
  .landing-hero :global(.hero .actions) {
    justify-content: center;
  }
  /*
   * The procedural nebula (NebulaBackground.astro, attachToBody) is a
   * fixed full-page backdrop mounted on <body>; the styling that pins it
   * and clears the page background lives in custom.css. The hero itself
   * is transparent so the cosmos shows through.
   *
   * The static control-loop line art competed visually with the nebula,
   * so it is hidden. Kept in the markup (aria-hidden) so a future change
   * can restore it as an overlay if wanted.
   */
  .landing-hero-art {
    display: none;
  }
  /*
   * The hero (and the whole landing page) now sits on a dark cosmic
   * backdrop, so hero text is forced light in both colour themes for
   * legibility. Scoped to the landing hero so interior doc pages keep
   * their theme-driven colours.
   */
  /* Kicker label above the H1, mirroring the nebula-demo splash: small
     upper-case cyan wordmark that names the brand over the big headline. */
  .hero-kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.26em;
    font-size: 0.75rem;
    font-weight: 600;
    color: #50e6ff;
  }
  .landing-hero :global(.tagline) {
    color: #c3d1ea;
    font-size: clamp(1.05rem, 1.8vw, 1.3rem);
    max-width: 44rem;
    margin-inline: auto;
    line-height: 1.6;
  }
  /*
   * On narrow screens the SVG competes with the hero text for pixels,
   * so we hide it below 60rem - the hero still renders with the glow
   * and gradient title alone, which are enough at that width.
   */
  @media (max-width: 60rem) {
    .landing-hero-art {
      display: none;
    }
  }
  /* Gradient sweep on the hero title. Scoped to the landing hero so
     it does not leak into interior doc pages. */
  .landing-hero :global(h1) {
    background: linear-gradient(90deg, var(--sl-color-text-accent), #50e6ff);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    font-weight: 700;
    letter-spacing: -0.015em;
    font-size: clamp(2.6rem, 6vw, 4.8rem);
    line-height: 1.05;
  }

  /*
   * Animated control-loop layer (P1). The SVG is decorative
   * (aria-hidden), so this is pure visual enhancement with no text or
   * i18n. Every animation below is switched off under
   * prefers-reduced-motion, leaving the original static composition.
   *
   *   - Edges carry a travelling dash pattern, reading as events
   *     flowing left-to-right: inflow -> router -> tier outputs.
   *   - The router rings and the T0/T1/T2 output rings pulse.
   *   - A packet dot rides each of the three tier lanes.
   *   - Incoming event dots twinkle out of phase.
   */
  .hero-funnel-edges path,
  .hero-tier-lanes path {
    stroke-dasharray: 5 7;
    animation: hero-flow 1.6s linear infinite;
  }
  .hero-tier-lanes path {
    animation-duration: 1.9s;
  }
  @keyframes hero-flow {
    to {
      stroke-dashoffset: -24;
    }
  }

  .hero-router-pulse,
  .hero-out-pulse {
    animation: hero-pulse 3s ease-in-out infinite;
  }
  .hero-router-pulse.ring-2 {
    animation-delay: 0.6s;
  }
  /* Opacity-only pulse: no transform, so it needs no transform-box
     support and cannot mis-anchor the ring on older engines. */
  @keyframes hero-pulse {
    0%,
    100% {
      opacity: 0.15;
    }
    50% {
      opacity: 0.6;
    }
  }

  /* Packets ride the tier lanes only where offset-path is supported.
     Their markup default is opacity 0, so an engine without offset-path
     simply keeps them invisible instead of blinking a dot at (0,0). */
  @supports (offset-path: path("M0 0 L1 1")) {
    .hero-packet {
      animation: hero-packet-move 3.4s cubic-bezier(0.5, 0, 0.5, 1) infinite;
    }
    .hero-packet--t0 {
      offset-path: path("M416 200 Q560 130 720 90");
    }
    .hero-packet--t1 {
      offset-path: path("M416 200 L720 200");
      animation-delay: 0.5s;
    }
    .hero-packet--t2 {
      offset-path: path("M416 200 Q560 270 720 310");
      animation-delay: 1s;
    }
  }
  @keyframes hero-packet-move {
    0% {
      offset-distance: 0%;
      opacity: 0;
    }
    12% {
      opacity: 1;
    }
    82% {
      opacity: 1;
    }
    100% {
      offset-distance: 100%;
      opacity: 0;
    }
  }

  .hero-events circle {
    animation: hero-twinkle 2.4s ease-in-out infinite;
  }
  .hero-events circle:nth-child(2n) {
    animation-delay: 0.8s;
  }
  .hero-events circle:nth-child(3n) {
    animation-delay: 1.4s;
  }
  @keyframes hero-twinkle {
    0%,
    100% {
      opacity: 0.35;
    }
    50% {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-funnel-edges path,
    .hero-tier-lanes path,
    .hero-router-pulse,
    .hero-out-pulse,
    .hero-packet,
    .hero-events circle {
      animation: none;
    }
  }
</style>

