---
/*
 * DocsPageFrame.astro - passthrough over Starlight's default page frame.
 *
 * Documentation content renders on the standard (flat) background. The
 * decorative WebGL nebula is reserved for the landing splash (CustomHero);
 * doc pages intentionally do not carry an atmospheric backdrop so the
 * content reads on a clean surface, consistent across every doc route.
 */
import Default from "@astrojs/starlight/components/PageFrame.astro";
---

<Default>
  <slot name="header" slot="header" />
  <slot name="sidebar" slot="sidebar" />
  <slot />
</Default>
