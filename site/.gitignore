# Astro / Starlight build outputs
node_modules/
dist/
.astro/

# Generated symlinks (see scripts/mount-docs.mjs). Regenerated on every
# `npm run dev` / `npm run build` from docs/roadmap/, which stays canonical.
# Only the roadmap subtree is generated; anything else under docs/ (like
# hand-authored ko/index.mdx or user-guide pages) is source and stays tracked.
src/content/docs/reference/roadmap/
src/content/docs/ko/reference/roadmap/

# Stale-translation manifest generated by scripts/mount-docs.mjs — the
# authoritative source is docs/roadmap/**/*-ko.md's translation_source_sha
# vs git hash-object of the English sibling. Regenerated every mount.
src/data/stale-translations.json

# Environment overrides (site can be built for a fork without editing config)
.env
.env.*
!.env.example

# Editor
.DS_Store
